Options -Indexes
RewriteEngine On

# Pass Authorization header to PHP (Apache strips it by default with CGI/FastCGI)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# API
RewriteRule ^api/(.*)$ api/index.php [L,QSA]

# SPA
RewriteRule !\.(js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot)$ public/index.php [L]

# Archivos estáticos
RewriteRule ^(css|js|img|fonts)/(.*)$ public/$1/$2 [L]
