Options -Indexes
RewriteEngine On

# Pass Authorization header to PHP (Apache strips it by default with CGI/FastCGI)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Archivos estáticos - redirigir a public/
RewriteRule ^(css|js|img|fonts)/(.*)$ public/$1/$2 [L]

# API
RewriteRule ^api/(.*)$ api/index.php [L,QSA]

# SPA - todo lo demas
RewriteRule ^(.*)$ public/index.php [L]
